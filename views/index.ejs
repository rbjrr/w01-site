<%- include('partials/header') %>
  <section class="hero">
    <div class="hero-content">
      <h1>Welcome to <%= title %></h1>
      <p>Connecting volunteers with organizations and projects that make a real difference in our community.</p>
      <a href="/projects" class="btn-primary">Explore Service Projects</a>
    </div>
    <div class="hero-image-wrapper">
      <img src="/images/volunteer.jpg" alt="Group of smiling volunteers standing together outdoors" class="hero-image">
    </div>
  </section>

  <section class="content-section">
    <h2>Why Volunteer With Us?</h2>
    <div class="card-grid">
      <div class="card">
        <h3>Find Organizations</h3>
        <p>Discover local and national organizations doing meaningful work in your area.</p>
      </div>
      <div class="card">
        <h3>Join Projects</h3>
        <p>Browse active service projects and sign up to lend a hand where it's needed most.</p>
      </div>
      <div class="card">
        <h3>Pick a Category</h3>
        <p>Filter opportunities by category to find the cause that matters most to you.</p>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
