<%- include('partials/header') %>

  <section class="page-heading">
    <h1><%= title %></h1>
    <p>Meet the organizations we partner with to bring service opportunities to the community.</p>
  </section>

  <section class="content-section">
    <div class="card-grid">
      <div class="card org-card">
        <img src="/images/org1.svg" alt="Green Earth Alliance logo" class="org-image" />
        <h3>Green Earth Alliance</h3>
        <p>A nonprofit focused on environmental cleanup, tree planting, and sustainability education.</p>
      </div>
      <div class="card org-card">
        <img src="/images/org2.svg" alt="Bright Futures Reading logo" class="org-image" />
        <h3>Bright Futures Reading</h3>
        <p>Volunteers tutor and mentor local students to improve literacy and academic confidence.</p>
      </div>
      <div class="card org-card">
        <img src="/images/org3.svg" alt="Helping Hands Shelter logo" class="org-image" />
        <h3>Helping Hands Shelter</h3>
        <p>Provides meals, supplies, and support to families experiencing homelessness.</p>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
