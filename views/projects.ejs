<%- include('partials/header') %>

  <section class="page-heading">
    <h1><%= title %></h1>
    <p>Upcoming and ongoing projects that need volunteers like you.</p>
  </section>

  <section class="content-section">
    <div class="card-grid">
      <div class="card">
        <h3>Community Park Cleanup</h3>
        <p>Join us for a morning of trash pickup and landscaping at the downtown community park.</p>
      </div>
      <div class="card">
        <h3>After-School Tutoring</h3>
        <p>Help elementary students with reading and homework twice a week.</p>
      </div>
      <div class="card">
        <h3>Winter Coat Drive</h3>
        <p>Collect and distribute warm coats to families in need before winter arrives.</p>
      </div>
      <div class="card">
        <h3>Food Bank Sorting</h3>
        <p>Sort and pack donated food items for weekly distribution to local families.</p>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
